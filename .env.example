# Configuración de Variables de Entorno para Pruebas
# QA Automation Framework - Example environment variables

# ─── Credenciales de Prueba ───────────────────────────────────────────────
TEST_USERNAME=test_user
TEST_PASSWORD=test_password
TEST_EMAIL=test@example.com

# ─── URLs Base ────────────────────────────────────────────────────────────
BASE_URL=https://example.test/app
API_BASE_URL=https://api.example.test/v1
ADMIN_URL=https://admin.example.test

# ─── Configuración de Navegadores ────────────────────────────────────────
BROWSER=chrome
HEADLESS_MODE=false
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080

# ─── Timeouts (en segundos) ────────────────────────────────────────────
IMPLICIT_WAIT=10
EXPLICIT_WAIT=15
PAGE_LOAD_TIMEOUT=20

# ─── Configuración de Reportes ────────────────────────────────────────────
ENABLE_SCREENSHOTS=true
SCREENSHOTS_PATH=./build/screenshots
ENABLE_VIDEOS=false
VIDEOS_PATH=./build/videos

# ─── Configuración de Logs ────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_PATH=./build/logs

# ─── Proxies (si es necesario) ────────────────────────────────────────────
# PROXY_HOST=proxy.example.test
# PROXY_PORT=8080
# PROXY_USERNAME=
# PROXY_PASSWORD=

# ─── Configuración de Base de Datos (si es necesario) ──────────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=test_app
# DB_USER=test_user
# DB_PASSWORD=test_password

# ─── Configuración de Certificados (para HTTPS) ───────────────────────────
# KEYSTORE_PATH=/ruta/al/keystore
# KEYSTORE_PASSWORD=password

# ─── Configuración de Slack (para notificaciones) ────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_CHANNEL=#qa-automation

# ─── Configuración de Email (para reportes) ────────────────────────────
# EMAIL_FROM=qa@example.test
# EMAIL_TO=qa-team@example.test
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587

# ─── Ambiente de Ejecución ────────────────────────────────────────────────
ENVIRONMENT=DEV
EXECUTION_MODE=local
